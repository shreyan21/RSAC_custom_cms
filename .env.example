# Frontend CMS template. Copy to `.env.local`; never add DB/admin secrets.
# VITE_* values are public browser configuration.
VITE_CMS_ENABLED=true
VITE_CMS_PROVIDER=drupal
VITE_CMS_URL=https://cms.example.gov.in
# Optional alias. If present, this wins over VITE_CMS_URL for Drupal.
# VITE_DRUPAL_URL=https://cms.example.gov.in
VITE_CMS_REQUEST_TIMEOUT=20000

# Drupal JSON:API. Do not hardcode production URLs in source.
VITE_DRUPAL_JSONAPI_PATH=/jsonapi
VITE_DRUPAL_LANGUAGE_PREFIX_MODE=path
# VITE_DRUPAL_API_TOKEN=read-only-public-token-if-required
# VITE_DRUPAL_FEEDBACK_PATH=/rsac-api/feedback
# VITE_DRUPAL_VISIT_PATH=/rsac-api/visit
# VITE_DRUPAL_VISIT_COUNT_PATH=/rsac-api/visit-count

# Drupal bundle machine names. Keep defaults unless site builder used another name.
# VITE_DRUPAL_PAGE_BUNDLE=rsac_page
# VITE_DRUPAL_PAGE_SECTION_BUNDLE=rsac_page_section
# VITE_DRUPAL_SECTION_ITEM_BUNDLE=rsac_section_item
# VITE_DRUPAL_DIVISION_BUNDLE=rsac_division
# VITE_DRUPAL_DOWNLOAD_BUNDLE=rsac_download
# VITE_DRUPAL_GALLERY_BUNDLE=rsac_gallery_item
# VITE_DRUPAL_NOTICE_BUNDLE=rsac_notice_tender_faq
# VITE_DRUPAL_PROJECT_BUNDLE=rsac_project
# VITE_DRUPAL_PUBLICATION_BUNDLE=rsac_publication
# VITE_DRUPAL_MENU_BUNDLE=rsac_menu_item
# VITE_DRUPAL_SITE_SETTING_BUNDLE=rsac_site_setting

# Optional Directus fallback while Drupal migration is incomplete.
VITE_DIRECTUS_FALLBACK_ENABLED=false
# VITE_DIRECTUS_FALLBACK_URL=https://old-directus.example.gov.in
# VITE_DIRECTUS_TOKEN=read-only-public-token
# VITE_DIRECTUS_VISITS_COLLECTION=rsac_site_visits

# Optional CMS preview. Keep disabled on the live public site.
# When enabled, open /?preview=<token> on a staging/local website to view draft
# Directus rows. Use a read-only Directus token that is allowed to read drafts.
# VITE_CMS_PREVIEW_ENABLED=false
# VITE_CMS_PREVIEW_TOKEN=change-this-preview-token
# VITE_DIRECTUS_PREVIEW_TOKEN=read-only-draft-preview-token
