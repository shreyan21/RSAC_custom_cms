# Public browser settings. These values are visible to site visitors.
VITE_API_URL=http://localhost:3000
VITE_WEBSITE_URL=http://localhost:5173
VITE_API_TIMEOUT=15000

# Express CMS service.
CMS_PORT=3000
CMS_PUBLIC_URL=http://localhost:3000
CMS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:5174,http://127.0.0.1:5173,http://127.0.0.1:5174
CMS_COOKIE_SECURE=true
CMS_SESSION_HOURS=8
CMS_UPLOAD_DIR=server/uploads
CMS_MAX_UPLOAD_BYTES=26214400

# PostgreSQL setup names. Put real passwords only in ignored .env.local.
POSTGRES_HOST=127.0.0.1
POSTGRES_PORT=5432
POSTGRES_ADMIN_USER=postgres
POSTGRES_ADMIN_PASSWORD=set-locally
CMS_DATABASE_NAME=rsac_custom_cms
CMS_DATABASE_USER=rsac_custom_app
CMS_DATABASE_URL=postgresql://rsac_custom_app:replace-locally@127.0.0.1:5432/rsac_custom_cms
CMS_ADMIN_USERNAME=admin
CMS_ADMIN_PASSWORD=replace-locally
