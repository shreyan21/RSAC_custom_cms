# Replace rsac.example.gov.in, cms.example.gov.in, and certificate paths
# before enabling this file.

server {
    listen 80;
    server_name rsac.example.gov.in;
    return 301 https://$host$request_uri;
}

server {
    listen 443 ssl;
    http2 on;
    server_name rsac.example.gov.in;

    ssl_certificate /etc/letsencrypt/live/rsac.example.gov.in/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/rsac.example.gov.in/privkey.pem;

    root /var/www/rsac-up/dist;
    index index.html;

    # Compress text assets. The main JS bundle is ~790 KB raw / ~216 KB gzipped.
    gzip on;
    gzip_vary on;
    gzip_comp_level 6;
    gzip_min_length 1024;
    gzip_types
        text/css
        text/plain
        text/xml
        application/javascript
        application/json
        application/xml
        image/svg+xml;

    # Security headers (GIGW/STQC). Keep in sync with the CMS host template.
    add_header X-Content-Type-Options "nosniff" always;
    add_header X-Frame-Options "SAMEORIGIN" always;
    add_header Referrer-Policy "strict-origin-when-cross-origin" always;
    add_header Permissions-Policy "camera=(), microphone=(), geolocation=()" always;
    add_header Strict-Transport-Security "max-age=31536000; includeSubDomains" always;
    # Content-Security-Policy notes:
    # - style-src 'unsafe-inline' is required (React inline styles / framer-motion).
    # - frame-src allows the Google Maps embed on the Location section and
    #   same-origin + CMS-hosted PDF previews.
    # - img/media/connect include the CMS origin for Directus assets and API.
    add_header Content-Security-Policy "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; font-src 'self'; img-src 'self' data: blob: https://cms.example.gov.in; media-src 'self' https://cms.example.gov.in; connect-src 'self' https://cms.example.gov.in; frame-src 'self' https://www.google.com https://cms.example.gov.in; object-src 'none'; base-uri 'self'; form-action 'self'; frame-ancestors 'self'" always;

    # Hashed build assets never change: cache forever.
    location /assets/ {
        try_files $uri =404;
        expires 30d;
        add_header Cache-Control "public, immutable";
    }

    # index.html must always be revalidated, or browsers keep serving an old
    # build whose hashed asset URLs no longer exist after a redeploy.
    # NOTE: nginx add_header does not inherit into a location that sets its own
    # headers, so the security set is repeated here.
    location = /index.html {
        add_header Cache-Control "no-cache" always;
        add_header X-Content-Type-Options "nosniff" always;
        add_header X-Frame-Options "SAMEORIGIN" always;
        add_header Referrer-Policy "strict-origin-when-cross-origin" always;
        add_header Permissions-Policy "camera=(), microphone=(), geolocation=()" always;
        add_header Strict-Transport-Security "max-age=31536000; includeSubDomains" always;
        add_header Content-Security-Policy "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; font-src 'self'; img-src 'self' data: blob: https://cms.example.gov.in; media-src 'self' https://cms.example.gov.in; connect-src 'self' https://cms.example.gov.in; frame-src 'self' https://www.google.com https://cms.example.gov.in; object-src 'none'; base-uri 'self'; form-action 'self'; frame-ancestors 'self'" always;
    }

    location / {
        try_files $uri $uri/ /index.html;
    }
}
