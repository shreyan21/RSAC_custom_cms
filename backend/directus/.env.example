# Private Directus config template. Copy to `.env` and replace every placeholder.
# Directus HTTP service
HOST=0.0.0.0
PORT=8055
PUBLIC_URL=http://localhost:8055
# Website address used by Directus Live Preview.
FRONTEND_URL=http://localhost:5173
LOG_LEVEL=info

# PostgreSQL connection
DB_CLIENT=pg
DB_HOST=127.0.0.1
DB_PORT=5432
DB_DATABASE=rsac_cms
DB_USER=rsac_directus
DB_PASSWORD=replace-with-the-postgresql-user-password

# Recovery only: uncomment when `cms:setup` must create a missing database.
# Remove both values immediately after setup succeeds.
# DB_ADMIN_USER=postgres
# DB_ADMIN_PASSWORD=replace-with-postgresql-admin-password

# Directus application secrets and initial administrator
KEY=replace-with-at-least-32-random-characters
SECRET=replace-with-at-least-64-random-characters
ADMIN_EMAIL=admin@example.gov.in
ADMIN_PASSWORD=replace-with-a-strong-admin-password

# Browser and transport security
CORS_ENABLED=true
CORS_ORIGIN=http://localhost:5173
CORS_CREDENTIALS=false
REFRESH_TOKEN_COOKIE_SECURE=false
REFRESH_TOKEN_COOKIE_SAME_SITE=lax
SESSION_COOKIE_SECURE=false
SESSION_COOKIE_SAME_SITE=lax
HSTS_ENABLED=false

# Abuse protection
RATE_LIMITER_ENABLED=true
RATE_LIMITER_POINTS=50
RATE_LIMITER_DURATION=1
PRESSURE_LIMITER_ENABLED=true

# Local file storage. Replace with an approved object-storage adapter if needed.
STORAGE_LOCATIONS=local
STORAGE_LOCAL_DRIVER=local
STORAGE_LOCAL_ROOT=./uploads
FILES_MAX_UPLOAD_SIZE=50mb
FILES_MIME_TYPE_ALLOW_LIST=image/*,video/mp4,application/pdf,text/csv,application/vnd.openxmlformats-officedocument.*
ASSETS_CACHE_TTL=30d
EXTENSIONS_PATH=./extensions

# Directus 12 requires the corresponding entitlement for filtered and
# field-limited public permission rules. Enable this after activating it.
DIRECTUS_STRICT_PUBLIC_PERMISSIONS=false

# Emergency recovery only. Keep false so seed commands cannot overwrite
# content entered by editors in Directus Studio.
DIRECTUS_ALLOW_FORCE_SEED=false

TELEMETRY=false
