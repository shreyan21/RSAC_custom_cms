{
  "name": "rsac_website",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "node scripts/dev-server.mjs",
    "build": "vite build",
    "cms:setup": "node scripts/drupal-setup-check.mjs",
    "cms:bootstrap:local": "node scripts/drupal-local-bootstrap.mjs",
    "cms:admin:install": "node scripts/drupal-sync-admin-module.mjs",
    "cms:migrate:rsac-db": ".\\.tools\\php\\php.exe .\\local-drupal\\vendor\\drush\\drush\\drush.php --root=.\\local-drupal\\web php:script .\\cms-drupal\\migrate-rsac-cms.php",
    "cms:seed:drupal": "node cms-drupal/export-seed-data.mjs && .\\.tools\\php\\php.exe .\\local-drupal\\vendor\\drush\\drush\\drush.php --root=.\\local-drupal\\web php:script .\\cms-drupal\\seed-content.php",
    "cms:start": "node scripts/drupal-start.mjs",
