# Drupal normal/manual deployment template.
# This is for server operators; do not commit real secrets.

DRUPAL_SITE_NAME="RSAC-UP Headless CMS"
DRUPAL_BASE_URL=https://cms.example.gov.in

# PHP/Composer Drupal docroot example.
DRUPAL_PROJECT_ROOT=/var/www/rsac-drupal
DRUPAL_DOCROOT=/var/www/rsac-drupal/web
DRUPAL_FILES_DIR=/var/www/rsac-drupal/web/sites/default/files

# PostgreSQL. Keep private and place real values in Drupal settings.php or server env.
DRUPAL_DB_HOST=127.0.0.1
DRUPAL_DB_PORT=5432
DRUPAL_DB_NAME=rsac_drupal
DRUPAL_DB_USER=rsac_drupal
DRUPAL_DB_PASSWORD=replace-with-private-password
DRUPAL_DB_DRIVER=pgsql

# Public frontend origin allowed by CORS/reverse proxy.
FRONTEND_URL=https://rsac.example.gov.in
